<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="?android:attr/colorBackground">

    <View 
        android:id="@+id/bgView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:elevation="0dp"
        android:background="@android:color/transparent">
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/settingsToolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Configurações"
            app:titleCentered="true" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- SEÇÃO: EXIBIÇÃO -->
            <TextView 
                android:layout_width="match_parent" 
                android:layout_height="wrap_content"
                android:text="Exibição e Grade" 
                android:textColor="?attr/colorPrimary" 
                android:textSize="13sp"
                android:textStyle="bold" 
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp"
                android:layout_marginStart="4dp" />
            
            <com.google.android.material.card.MaterialCardView 
                android:layout_width="match_parent" 
                android:layout_height="wrap_content" 
                app:cardCornerRadius="20dp" 
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutlineVariant"
                android:layout_marginBottom="24dp">
                
                <LinearLayout 
                    android:layout_width="match_parent" 
                    android:layout_height="wrap_content" 
                    android:orientation="vertical" 
                    android:padding="16dp">
                    
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView 
                            android:id="@+id/labelGrid"
                            android:layout_width="wrap_content" 
                            android:layout_height="wrap_content" 
                            android:text="Colunas na Grade"
                            android:textSize="16sp"
                            android:textColor="?attr/colorOnSurface" />
                        <TextView 
                            android:id="@+id/tvGridValue"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:text="2"
                            android:textStyle="bold"
                            android:textColor="?attr/colorPrimary" />
                    </RelativeLayout>
                    
                    <com.google.android.material.slider.Slider 
                        android:id="@+id/sliderGrid" 
                        android:layout_width="match_parent" 
                        android:layout_height="wrap_content" 
                        android:valueFrom="1.0" 
                        android:valueTo="5.0" 
                        android:stepSize="1.0"
                        android:layout_marginTop="8dp" />
                    
                    <View 
                        android:layout_width="match_parent" 
                        android:layout_height="1dp" 
                        android:background="?attr/colorOutlineVariant" 
                        android:layout_marginTop="12dp" 
                        android:layout_marginBottom="12dp" />
                    
                    <com.google.android.material.switchmaterial.SwitchMaterial 
                        android:id="@+id/switchUniformGrid" 
                        android:layout_width="match_parent" 
                        android:layout_height="wrap_content" 
                        android:text="Tamanho de Notas Uniforme"
                        android:textSize="16sp"
                        app:switchPadding="16dp" />

                    <View 
                        android:layout_width="match_parent" 
                        android:layout_height="1dp" 
                        android:background="?attr/colorOutlineVariant" 
                        android:layout_marginTop="12dp" 
                        android:layout_marginBottom="12dp" />

                    <com.google.android.material.switchmaterial.SwitchMaterial 
                        android:id="@+id/switch24h" 
                        android:layout_width="match_parent" 
                        android:layout_height="wrap_content" 
                        android:text="Usar Formato 24h"
                        android:textSize="16sp"
                        app:switchPadding="16dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- SEÇÃO: PERSONALIZAÇÃO -->
            <TextView 
                android:layout_width="match_parent" 
                android:layout_height="wrap_content"
                android:text="Personalização" 
                android:textColor="?attr/colorPrimary" 
                android:textSize="13sp"
                android:textStyle="bold" 
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp"
                android:layout_marginStart="4dp" />

            <com.google.android.material.card.MaterialCardView 
                android:layout_width="match_parent" 
                android:layout_height="wrap_content" 
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutlineVariant"
                android:layout_marginBottom="24dp">
                
                <LinearLayout 
                    android:layout_width="match_parent" 
                    android:layout_height="wrap_content" 
                    android:orientation="vertical">
                    
                    <RadioGroup 
                        android:id="@+id/rgThemes" 
                        android:layout_width="match_parent" 
                        android:layout_height="wrap_content" 
                        android:padding="8dp">
                        <RadioButton android:id="@+id/rbLight" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Light Theme" android:padding="12dp" />
                        <RadioButton android:id="@+id/rbPantera" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Pantera OLED Black" android:padding="12dp" />
                        <RadioButton android:id="@+id/rbDynamicBlack" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Material You Black" android:padding="12dp" />
                        <RadioButton android:id="@+id/rbDynamicLight" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Material You Light" android:padding="12dp" />
                    </RadioGroup>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="?attr/colorOutlineVariant" android:layout_marginStart="16dp" android:layout_marginEnd="16dp" />

                    <LinearLayout 
                        android:layout_width="match_parent" 
                        android:layout_height="wrap_content" 
                        android:orientation="vertical" 
                        android:padding="16dp">
                        <RelativeLayout android:layout_width="match_parent" android:layout_height="wrap_content">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Transparência de Widgets" android:textSize="16sp" android:textColor="?attr/colorOnSurface" />
                            <TextView android:id="@+id/tvTransparencyValue" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_alignParentEnd="true" android:text="100%" android:textStyle="bold" android:textColor="?attr/colorPrimary" />
                        </RelativeLayout>
                        <com.google.android.material.slider.Slider 
                            android:id="@+id/sliderTransparency" 
                            android:layout_width="match_parent" 
                            android:layout_height="wrap_content" 
                            android:valueFrom="0.0" 
                            android:valueTo="100.0" 
                            android:stepSize="5.0"
                            android:layout_marginTop="8dp" />
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="?attr/colorOutlineVariant" android:layout_marginStart="16dp" android:layout_marginEnd="16dp" />
                    
                    <com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/switchNotifyColor" android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp" android:text="Cores em Notificações" android:textSize="16sp" />
                    <com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/switchAlarmColor" android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp" android:text="Cores em Alarmes" android:textSize="16sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- SEÇÃO: ESTILO DOS CARDS -->
            <TextView 
                android:layout_width="match_parent" 
                android:layout_height="wrap_content"
                android:text="Estilo das Notas" 
                android:textColor="?attr/colorPrimary" 
                android:textSize="13sp"
                android:textStyle="bold" 
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp"
                android:layout_marginStart="4dp" />

            <com.google.android.material.card.MaterialCardView 
                android:layout_width="match_parent" 
                android:layout_height="wrap_content" 
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutlineVariant"
                android:layout_marginBottom="24dp">
                
                <RadioGroup 
                    android:id="@+id/rgCardStyles" 
                    android:layout_width="match_parent" 
                    android:layout_height="wrap_content" 
                    android:padding="8dp">
                    <RadioButton android:id="@+id/rbStyleLabel" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Etiqueta (Padrão)" android:padding="12dp" />
                    <RadioButton android:id="@+id/rbStylePastel" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Pastel (Suave)" android:padding="12dp" />
                    <RadioButton android:id="@+id/rbStyleSolid" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Solid (Vibrante)" android:padding="12dp" />
                </RadioGroup>
            </com.google.android.material.card.MaterialCardView>

            <!-- SEÇÃO: FUNDO -->
            <TextView 
                android:layout_width="match_parent" 
                android:layout_height="wrap_content"
                android:text="Fundo do Aplicativo" 
                android:textColor="?attr/colorPrimary" 
                android:textSize="13sp"
                android:textStyle="bold" 
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp"
                android:layout_marginStart="4dp" />

            <com.google.android.material.card.MaterialCardView 
                android:layout_width="match_parent" 
                android:layout_height="wrap_content" 
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutlineVariant"
                android:layout_marginBottom="24dp">
                
                <RadioGroup 
                    android:id="@+id/rgBgThemes" 
                    android:layout_width="match_parent" 
                    android:layout_height="wrap_content" 
                    android:padding="8dp">
                    <RadioButton android:id="@+id/rbBgDefault" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Padrão" android:padding="12dp" />
                    <RadioButton android:id="@+id/rbBgMesh" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Malha (Mesh)" android:padding="12dp" />
                    <RadioButton android:id="@+id/rbBgGeometric" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Geométrico" android:padding="12dp" />
                </RadioGroup>
            </com.google.android.material.card.MaterialCardView>

            <!-- SEÇÃO: SEGURANÇA -->
            <TextView 
                android:layout_width="match_parent" 
                android:layout_height="wrap_content"
                android:text="Privacidade e Segurança" 
                android:textColor="?attr/colorPrimary" 
                android:textSize="13sp"
                android:textStyle="bold" 
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp"
                android:layout_marginStart="4dp" />

            <com.google.android.material.card.MaterialCardView 
                android:layout_width="match_parent" 
                android:layout_height="wrap_content" 
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutlineVariant"
                android:layout_marginBottom="24dp">
                
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
                    <com.google.android.material.switchmaterial.SwitchMaterial android:id="@+id/switchBiometric" android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="16dp" android:text="Biometria do Dispositivo" android:textSize="16sp" />
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="?attr/colorOutlineVariant" android:layout_marginStart="16dp" android:layout_marginEnd="16dp" />
                    <com.google.android.material.button.MaterialButton 
                        android:id="@+id/btnSetAppPassword" 
                        style="@style/Widget.Material3.Button.TextButton" 
                        android:layout_width="match_parent" 
                        android:layout_height="wrap_content" 
                        android:text="Senha do Aplicativo" 
                        android:gravity="start|center_vertical" 
                        android:padding="16dp" 
                        app:icon="@drawable/ic_lock"
                        app:iconPadding="16dp"
                        android:textColor="?attr/colorOnSurface" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- SEÇÃO: PLANEJAMENTO -->
            <TextView 
                android:layout_width="match_parent" 
                android:layout_height="wrap_content"
                android:text="Planejamento e Repetições" 
                android:textColor="?attr/colorPrimary" 
                android:textSize="13sp"
                android:textStyle="bold" 
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp"
                android:layout_marginStart="4dp" />

            <com.google.android.material.card.MaterialCardView 
                android:layout_width="match_parent" 
                android:layout_height="wrap_content" 
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutlineVariant"
                android:layout_marginBottom="24dp">
                
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
                    <com.google.android.material.button.MaterialButton 
                        android:id="@+id/btnRecurringNotes" 
                        style="@style/Widget.Material3.Button.TextButton" 
                        android:layout_width="match_parent" 
                        android:layout_height="wrap_content" 
                        android:text="Ver Notas e Listas Recorrentes" 
                        android:gravity="start|center_vertical" 
                        android:padding="16dp" 
                        app:icon="@drawable/ic_calendar"
                        app:iconPadding="16dp"
                        android:textColor="?attr/colorOnSurface" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- SEÇÃO: DADOS -->
            <TextView 
                android:layout_width="match_parent" 
                android:layout_height="wrap_content"
                android:text="Gerenciamento" 
                android:textColor="?attr/colorPrimary" 
                android:textSize="13sp"
                android:textStyle="bold" 
                android:textAllCaps="true"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp"
                android:layout_marginStart="4dp" />

            <com.google.android.material.card.MaterialCardView 
                android:layout_width="match_parent" 
                android:layout_height="wrap_content" 
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeWidth="1dp"
                app:strokeColor="?attr/colorOutlineVariant"
                android:layout_marginBottom="24dp">
                
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
                    <com.google.android.material.button.MaterialButton 
                        android:id="@+id/btnTrash" 
                        style="@style/Widget.Material3.Button.TextButton" 
                        android:layout_width="match_parent" 
                        android:layout_height="wrap_content" 
                        android:text="Gerenciar Lixeira" 
                        android:gravity="start|center_vertical" 
                        android:padding="16dp" 
                        app:icon="@drawable/ic_delete"
                        app:iconPadding="16dp"
                        android:textColor="?attr/colorOnSurface" />
                    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="?attr/colorOutlineVariant" android:layout_marginStart="16dp" android:layout_marginEnd="16dp" />
                    <com.google.android.material.button.MaterialButton 
                        android:id="@+id/btnResetAll" 
                        style="@style/Widget.Material3.Button.TextButton" 
                        android:layout_width="match_parent" 
                        android:layout_height="wrap_content" 
                        android:text="Limpar Todos os Dados" 
                        android:textColor="#F44336" 
                        android:gravity="start|center_vertical" 
                        android:padding="16dp" 
                        app:icon="@drawable/ic_revert"
                        app:iconTint="#F44336"
                        app:iconPadding="16dp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- SEÇÃO: SOBRE -->
            <com.google.android.material.card.MaterialCardView 
                android:layout_width="match_parent" 
                android:layout_height="wrap_content" 
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="?attr/colorSurfaceVariant">
                <LinearLayout 
                    android:layout_width="match_parent" 
                    android:layout_height="wrap_content" 
                    android:orientation="vertical" 
                    android:padding="20dp"
                    android:gravity="center_horizontal">
                    <TextView 
                        android:layout_width="wrap_content" 
                        android:layout_height="wrap_content" 
                        android:text="Notara_" 
                        android:textSize="22sp" 
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnSurfaceVariant" />
                    <TextView 
                        android:layout_width="wrap_content" 
                        android:layout_height="wrap_content" 
                        android:text="Produtividade e Segurança" 
                        android:textSize="14sp"
                        android:alpha="0.7"
                        android:textColor="?attr/colorOnSurfaceVariant" />
                    <TextView 
                        android:id="@+id/tvVersion" 
                        android:layout_width="wrap_content" 
                        android:layout_height="wrap_content" 
                        android:text="v2.1 Build 2026.04" 
                        android:layout_marginTop="12dp" 
                        android:textSize="12sp"
                        android:alpha="0.5"
                        android:textColor="?attr/colorOnSurfaceVariant" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
