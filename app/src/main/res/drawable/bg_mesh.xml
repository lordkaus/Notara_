<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#00000000" />
        </shape>
    </item>
    <!-- Simulação de Mesh com gradientes cruzados -->
    <item>
        <gradient 
            android:type="radial" 
            android:gradientRadius="400dp" 
            android:startColor="#1A4DB6AC" 
            android:endColor="#00000000" 
            android:centerX="0.2" 
            android:centerY="0.2" />
    </item>
    <item>
        <gradient 
            android:type="radial" 
            android:gradientRadius="600dp" 
            android:startColor="#1A9575CD" 
            android:endColor="#00000000" 
            android:centerX="0.8" 
            android:centerY="0.8" />
    </item>
</layer-list>