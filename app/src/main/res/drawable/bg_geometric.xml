<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#00000000" />
        </shape>
    </item>
    <item android:top="40dp" android:left="40dp">
        <rotate android:fromDegrees="45" android:pivotX="0%" android:pivotY="0%">
            <shape android:shape="rectangle">
                <size android:width="200dp" android:height="200dp" />
                <solid android:color="#0D4DB6AC" />
            </shape>
        </rotate>
    </item>
    <item android:bottom="100dp" android:right="20dp">
        <rotate android:fromDegrees="15" android:pivotX="100%" android:pivotY="100%">
            <shape android:shape="rectangle">
                <size android:width="300dp" android:height="300dp" />
                <solid android:color="#0D9575CD" />
            </shape>
        </rotate>
    </item>
</layer-list>